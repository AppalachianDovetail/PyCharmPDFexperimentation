# May2026  Aim is to split multiple csvs into a .ods with tabs for each day,
# with each date having tabs for each source file (X, Y, Z)
# Modified to process multiple source CSV files and organize by date
# This version May 2026 includes data validation elements.

import pandas as pd
from datetime import date
from pathlib import Path
import shutil
import glob

source_folder = Path('spam path here')
# Automatically find all CSV files in the source folder
source_files = sorted(Path(source_folder).glob('*.csv'))
# below is so our output file is named with today's date
today = date.today()
output_file = f"{today}.ods"
warning_file = f"{today}_INVALID_DATA_WARNING.txt"
archive_folder = Path('path to spam archive folder')

required_columns = ['ticket', 'Received', 'Payment Type']


def validate_csv_format(df, source_file, required_columns):
    """
    Validate that the CSV has the expected columns and can be processed.
    Returns (is_valid, error_message)
    """
    missing_columns = [col for col in required_columns if col not in df.columns]
    
    if missing_columns:
        error_msg = (
            f"Missing required column(s): {', '.join(missing_columns)}. "
            f"Found columns: {', '.join(df.columns)}"
        )
        return False, error_msg
    
    # Check if 'Received' column can be parsed as datetime
    try:
        pd.to_datetime(df['Received'], format='%d/%m/%y %H:%M:%S')
    except Exception as e:
        return False, f"'Received' column cannot be parsed as datetime: {str(e)}"
    
    return True, None


# Create a dictionary to store modified dataframes for each sheet
sheets_to_write = {}
invalid_files = []

# Process each source file
for source_file in source_files:
    df = pd.read_csv(source_file)
    
    # Validate before processing
    is_valid, error = validate_csv_format(df, source_file, required_columns)
    
    if not is_valid:
        invalid_files.append((source_file.name, error))
        continue
    
    # below converts the date (in column called 'received')
    # from a regular object to a datetime object
    df['Received'] = pd.to_datetime(df['Received'], format='%d/%m/%y %H:%M:%S')
    
    # Extract the file name without extension for tab naming
    file_name = source_file.stem
    
    # Process each day's data for this source file
    for day, group in df.sort_values(['ticket']).groupby(df['Received'].dt.date):
        # Perform modifications on each group
        amtrac_total = group.loc[group['Payment Type'] == 'amtrac', 'ticket'].sum()
        all_total = group['ticket'].sum()
        new_rows = pd.DataFrame([
            {'ticket': ''},
            {'ticket': amtrac_total, 'Type': "amtrac_total"},
            {'ticket': ''},
            {'ticket': all_total, 'Type': "all_total"}
        ])
        modified_group = pd.concat([group, new_rows], ignore_index=True)
        
        # Create sheet name as "YYYY-MM-DD_SourceFileName" (Option B)
        sheet_name = f"{day}_{file_name}"
        sheets_to_write[sheet_name] = modified_group

# Check if there were invalid files
if invalid_files:
    # Write warning file instead of processing
    with open(source_folder / warning_file, 'w') as f:
        f.write("⚠️  DATA VALIDATION FAILED\n")
        f.write("=" * 60 + "\n\n")
        f.write(f"Generated: {today}\n")
        f.write(f"Required columns: {', '.join(required_columns)}\n\n")
        f.write("INVALID FILES:\n")
        f.write("-" * 60 + "\n")
        for filename, error_msg in invalid_files:
            f.write(f"\n❌ {filename}\n   {error_msg}\n")
        f.write("\n" + "=" * 60 + "\n")
        f.write("Please correct these CSV files and try again.\n")
    
    print(f"❌ Validation failed. Warning file created: {warning_file}")
else:
    # All files valid, write the ODS file
    with pd.ExcelWriter(source_folder / output_file, engine='odf') as writer:
        for sheet_name, sheet_df in sheets_to_write.items():
            sheet_df.to_excel(writer, sheet_name=sheet_name, index=False)
            
            # Below added 26Mar2026 to auto-adjust columns
            # For ODF engine, adjust column widths differently
            worksheet = writer.sheets[sheet_name]
            for idx, col in enumerate(sheet_df.columns, start=1):
                max_length = len(str(col))  # Start with header length
                for cell_value in sheet_df[col]:
                    try:
                        if len(str(cell_value)) > max_length:
                            max_length = len(str(cell_value))
                    except:
                        pass
                adjusted_width = min(max_length + 2, 50)  # Add 2 for padding, cap at 50
                # Set column width using column index (1-based)
                worksheet.set_column_width(idx, adjusted_width / 7)  # ODF uses different width units
    
    print(f"✓ Successfully created: {output_file}")
    
    # Archive the source CSV files with today's date in the filename
    for source_file in source_files:
        # Create new filename with today's date: "filename_2026-03-17.csv"
        file_stem = source_file.stem
        file_extension = source_file.suffix
        archived_filename = f"{file_stem}_{today}{file_extension}"
        archived_path = archive_folder / archived_filename
        
        # Move the file to archive folder
        if source_file.exists():
            shutil.move(str(source_file), str(archived_path))
            print(f"Archived: {source_file.name} → {archived_filename}")


# Validation function** at the top that checks for required columns and datetime parsing
# Collects invalid files** in a list during processing
# Conditional logic** that checks if any files failed validation:
#   - **If invalid:** Creates a readable warning file (`YYYY-MM-DD_INVALID_DATA_WARNING.txt`) with details about what went wrong
#   - **If valid:** Proceeds with creating the `.ods` file as normal and archives the CSVs
4. **Clear user feedback** printed to console indicating which outcome occurred

The warning file will show exactly which files failed and why, making it easy for you to diagnose and fix the problem.

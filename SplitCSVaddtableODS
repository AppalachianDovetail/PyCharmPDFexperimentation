# Archive the source CSV files with today's date in the filename
for source_file in source_files:
    # Create new filename with today's date: "filename_2026-03-17.csv"
    file_stem = source_file.stem
    file_extension = source_file.suffix
    archived_filename = f"{file_stem}_{today}{file_extension}"
    archived_path = archive_folder / archived_filename
    
    # Move the file to archive folder
    if source_file.exists():
        shutil.move(str(source_file), str(archived_path))
        print(f"Archived: {source_file.name} → {archived_filename}")

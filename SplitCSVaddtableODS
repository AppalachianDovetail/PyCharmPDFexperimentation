# Mar2026  Aim is to split multiple csvs into a .ods with tabs for each day,
# with each date having tabs for each source file (X, Y, Z)
# Modified to process multiple source CSV files and organize by date

import pandas as pd
from datetime import date
from pathlib import Path
import shutil
import glob

source_folder = Path('spam path here')
# Automatically find all CSV files in the source folder
source_files = sorted(Path(source_folder).glob('*.csv'))
# below is so our output file is named with today's date
today = date.today()
output_file = f"{today}.ods"
archive_folder = Path('path to spam archive folder')

# Create a dictionary to store modified dataframes for each sheet
sheets_to_write = {} 

# Process each source file
for source_file in source_files:
    df = pd.read_csv(source_file)
    
    # below converts the date (in column called 'received')
    # from a regular object to a datetime object
    df['Received'] = pd.to_datetime(df['Received'], format='%d/%m/%y %H:%M:%S')
    
    # Extract the file name without extension for tab naming
    file_name = source_file.stem
    
    # Process each day's data for this source file
    for day, group in df.sort_values(['ticket']).groupby(df['Received'].dt.date):
        # Perform modifications on each group
        amtrac_total = group.loc[group['Payment Type'] == 'amtrac', 'ticket'].sum()
        all_total = group['ticket'].sum()
        new_rows = pd.DataFrame([
            {'ticket': ''},
            {'ticket': amtrac_total, 'Type': "amtrac_total"},
            {'ticket': ''},
            {'ticket': all_total, 'Type': "all_total"}
        ])
        modified_group = pd.concat([group, new_rows], ignore_index=True)
        
        # Create sheet name as "YYYY-MM-DD_SourceFileName" (Option B)
        sheet_name = f"{day}_{file_name}"
        sheets_to_write[sheet_name] = modified_group

# Write all sheets in one operation
with pd.ExcelWriter(source_folder / output_file, engine='odf') as writer:
    for sheet_name, sheet_df in sheets_to_write.items():
        sheet_df.to_excel(writer, sheet_name=sheet_name, index=False)


# worksheet3.set_default_row(50) #Ok, this changes height of ALL ROWS on this sheet. Yay! 50=1.75cm...
# worksheet3.set_default_row(25) #Ok, this changes height of ALL ROWS on this sheet. Yay! 25=0.87cm...
# so a value of 1 = 0.035 cm. I want 0.45cm...
worksheet3.set_default_row(13) # gives row height of 0.45cm on this worksheet.


workbook.close()

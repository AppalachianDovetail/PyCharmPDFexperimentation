# 18Apr2026 Aim here is to show how to open xlsx file and save as ods,

import subprocess
from pathlib import Path

source_folder = Path('/Spampath')
source_file = '2026-04-19.xlsx'
output_file = "2026-04-19.ods"

input_path = source_folder / source_file
output_path = source_folder / output_file

# Below is for error-handling. If it can't find the source file it will say so.
try:
    if not input_path.exists():
        raise FileNotFoundError(f"Source file not found: {input_path}")

    # Use LibreOffice to convert
    subprocess.run([
        'libreoffice', '--headless', '--convert-to', 'ods',
        '--outdir', str(source_folder),
        str(input_path)
    ], check=True)

    print(f"✓ Successfully converted {source_file} to ODS")

except FileNotFoundError as e:
    print(f"✗ Error: {e}")
except subprocess.CalledProcessError as e:
    print(f"✗ LibreOffice conversion failed: {e}")



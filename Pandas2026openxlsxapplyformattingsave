# Mar2026 Aim here is to show how to open xlsx file and apply formatting

from datetime import date
from openpyxl import load_workbook
from openpyxl.styles import Font, PatternFill, Alignment, Border, Side
from pathlib import Path

source_folder = Path('your spam path here')
source_file = '2026-03-07.xlsx' # three tabs, all 11pt font
today = date.today()
output_file = f"{today}.xlsx"

wb = load_workbook(source_folder/source_file)

# Apply formatting to all sheets
for sheet_name in wb.sheetnames:
    ws = wb[sheet_name]

    # Below insert added 16Mar2026 to add Header/Footer functionality
    # Below adds the sheet name to the header of the sheet so it will print as a title.
    ws.oddHeader.center.text = sheet_name
    ws.oddHeader.center.size = 9
    ws.oddHeader.center.font = "Arial"
    # It is duplicated odd and even because if this prints across multiple pages it will alternate the text
    ws.evenHeader.center.text = sheet_name
    ws.evenHeader.center.size = 9
    ws.evenHeader.center.font = "Arial"
    # Below adds page no to footer
    ws.oddFooter.center.text = "Page &[Page]"
    ws.oddFooter.center.size = 9
    ws.oddFooter.center.font = "Arial"
    # It is duplicated odd and even because if this prints across multiple pages it will alternate the text
    ws.evenFooter.center.text = "Page &[Page]"
    ws.evenFooter.center.size = 9
    ws.evenFooter.center.font = "Arial"
    # Above is insert 16Mar2026 to add header/footer functionality
    # Example: Format header row (e.g., row 1)
    for cell in ws[1]:  # First row
        # cell.font = Font(bold=True, color="FFFFFF")
        # cell.font = Font(bold=True, size=9)
        # cell.fill = PatternFill(start_color="333333", end_color="333333", fill_type="solid")
        cell.alignment = Alignment(horizontal="center")
        # above can set style for row 1, unless overwritten by settings for all columns below.

    # Example: Set column widths
    for col in ws.columns:
        max_length = 0
        column = col[0].column_letter
        for cell in col:
            try:
                if len(str(cell.value)) > max_length:
                    max_length = len(str(cell.value))
            except:
                pass
            cell.font = Font(name="Arial", bold=False, size=9) # this is all cells, so overwrites the header stuff above
        adjusted_width = min(max_length + 2, 50)
        ws.column_dimensions[column].width = adjusted_width

